<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<title>{{ blueprint.title }} Study Guide</title>
	<style>
		@page {
			size: A4;
			margin: 18mm 16mm 18mm 16mm;
		}

		:root {
			--ink: #1f2933;
			--muted: #52606d;
			--line: #d9e2ec;
			--surface: #f7fafc;
			--accent: #1d4d72;
			--accent-soft: #e6eff5;
			--success: #d9f2e3;
			--warning: #fef3c7;
		}

		* {
			box-sizing: border-box;
		}

		body {
			margin: 0;
			color: var(--ink);
			font-family: "DejaVu Serif", Georgia, serif;
			font-size: 11pt;
			line-height: 1.45;
		}

		h1,
		h2,
		h3,
		h4 {
			margin: 0 0 0.35rem;
			color: var(--accent);
			font-family: "DejaVu Sans", "Trebuchet MS", sans-serif;
			line-height: 1.2;
		}

		h1 {
			font-size: 22pt;
		}

		h2 {
			font-size: 16pt;
			padding-bottom: 0.2rem;
			border-bottom: 2px solid var(--line);
			margin-bottom: 0.65rem;
		}

		h3 {
			font-size: 12.5pt;
			margin-top: 0.8rem;
		}

		h4 {
			font-size: 10.5pt;
			margin-top: 0.55rem;
		}

		.section-heading {
			display: block;
		}

		.heading-icon {
			display: inline-block;
			width: 1.1rem;
			height: 1.1rem;
			margin-right: 0.45rem;
			vertical-align: -0.18rem;
			color: var(--accent);
		}

		.icon-svg {
			width: 100%;
			height: 100%;
			stroke: currentColor;
			fill: none;
			stroke-width: 1.8;
			stroke-linecap: round;
			stroke-linejoin: round;
		}

		p,
		ul,
		ol,
		table,
		blockquote {
			margin: 0 0 0.7rem;
		}

		ul,
		ol {
			padding-left: 1.2rem;
		}

		li {
			margin-bottom: 0.25rem;
		}

		.cover {
			background: linear-gradient(180deg, #f9fbfc 0%, #eef4f7 100%);
			border: 1px solid var(--line);
			padding: 1.1rem 1.2rem;
			margin-bottom: 1rem;
		}

		.cover-meta {
			display: table;
			width: 100%;
			margin-top: 0.9rem;
			border-collapse: separate;
			border-spacing: 0.65rem;
		}

		.cover-meta-item {
			display: table-cell;
			background: white;
			border: 1px solid var(--line);
			padding: 0.6rem 0.7rem;
			vertical-align: top;
		}

		.eyebrow {
			color: var(--muted);
			font-family: "DejaVu Sans", "Trebuchet MS", sans-serif;
			font-size: 8.5pt;
			font-weight: bold;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			margin-bottom: 0.25rem;
		}

		.section {
			margin-bottom: 1rem;
			page-break-inside: avoid;
		}

		.section-body {
			background: white;
		}

		.callout {
			display: table;
			width: 100%;
			background: var(--surface);
			border-left: 4px solid var(--accent);
			padding: 0.7rem 0.8rem;
			margin-bottom: 0.8rem;
		}

		.callout-icon {
			display: table-cell;
			width: 1.45rem;
			padding-right: 0.55rem;
			vertical-align: top;
			color: var(--accent);
		}

		.callout-text {
			display: table-cell;
			vertical-align: top;
		}

		.callout.success {
			background: var(--success);
			border-left-color: #2f855a;
		}

		.callout.success .callout-icon {
			color: #2f855a;
		}

		.callout.warning {
			background: var(--warning);
			border-left-color: #b7791f;
		}

		.callout.warning .callout-icon {
			color: #b7791f;
		}

		.two-col {
			display: table;
			width: 100%;
			border-collapse: separate;
			border-spacing: 0.75rem 0;
		}

		.two-col > div {
			display: table-cell;
			width: 50%;
			vertical-align: top;
		}

		.boxed-list {
			border: 1px solid var(--line);
			background: var(--surface);
			padding: 0.7rem 0.8rem;
			margin-bottom: 0.8rem;
		}

		.target-item,
		.question-card,
		.strategy-card,
		.point-card,
		.example-card,
		.answer-card,
		.subconcept-card {
			border: 1px solid var(--line);
			padding: 0.8rem;
			margin-bottom: 0.75rem;
			break-inside: avoid;
		}

		.target-meta,
		.small-meta {
			color: var(--muted);
			font-size: 9pt;
			font-family: "DejaVu Sans", "Trebuchet MS", sans-serif;
		}

		.badge {
			display: inline-block;
			padding: 0.12rem 0.42rem;
			border: 1px solid var(--line);
			background: var(--surface);
			color: var(--muted);
			font-size: 8.5pt;
			font-family: "DejaVu Sans", "Trebuchet MS", sans-serif;
			text-transform: uppercase;
			letter-spacing: 0.04em;
			margin-right: 0.35rem;
			margin-bottom: 0.2rem;
		}

		.page-break {
			page-break-before: always;
		}

		table {
			width: 100%;
			border-collapse: collapse;
			font-size: 10pt;
		}

		th,
		td {
			border: 1px solid var(--line);
			padding: 0.45rem 0.5rem;
			vertical-align: top;
			text-align: left;
		}

		th {
			background: var(--accent-soft);
			color: var(--accent);
			font-family: "DejaVu Sans", "Trebuchet MS", sans-serif;
			font-size: 9pt;
			letter-spacing: 0.03em;
			text-transform: uppercase;
		}

		.passage {
			border: 1px solid var(--line);
			background: #fcfdff;
			padding: 0.9rem;
			margin-bottom: 0.8rem;
		}

		.passage p {
			margin-bottom: 0.65rem;
			text-indent: 1.2em;
		}

		.passage p:first-child {
			text-indent: 0;
		}

		.quote {
			font-style: italic;
			color: var(--muted);
		}
	</style>
</head>
<body>
	{% set section_map = sections|default({}, true) %}
	{% set validation_result = validation|default(none, true) %}
	{% set intro = section_map.intro|default(none, true) %}
	{% set learning_targets = section_map.learning_targets|default(none, true) %}
	{% set warmup = section_map.warmup|default(none, true) %}
	{% set vocabulary = section_map.vocabulary|default(none, true) %}
	{% set core_explainer = section_map.core_explainer|default(none, true) %}
	{% set subconcepts = section_map.subconcept|default([], true) %}
	{% set strategy_list = section_map.strategy_list|default(none, true) %}
	{% set deep_dive = section_map.deep_dive|default(none, true) %}
	{% set model_passage = section_map.model_passage|default(none, true) %}
	{% set check_in = section_map.check_in|default(none, true) %}
	{% set key_points = section_map.key_points|default(none, true) %}
	{% set assessment_passage = section_map.assessment_passage|default(none, true) %}
	{% set assessment_questions = section_map.assessment_questions|default(none, true) %}
	{% set step_up = section_map.step_up|default(none, true) %}
	{% set self_assessment = section_map.self_assessment|default(none, true) %}
	{% set answer_key = section_map.answer_key|default(none, true) %}
	{% set section_icons = section_icons|default({}, true) %}
	{% set ui_icons = ui_icons|default({}, true) %}

	{% macro icon_svg(icon_key) -%}
		{%- if icon_key == "spark" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 13.9 8.1 19 10 13.9 11.9 12 17 10.1 11.9 5 10 10.1 8.1Z" /></svg>
		{%- elif icon_key == "target" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8" /><circle cx="12" cy="12" r="4" /><path d="M12 2v3M12 19v3M2 12h3M19 12h3" /></svg>
		{%- elif icon_key == "lightning" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M13 2 5 14h5l-1 8 8-12h-5Z" /></svg>
		{%- elif icon_key == "book" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5.5C4 4.7 4.7 4 5.5 4H11v16H5.5C4.7 20 4 19.3 4 18.5Z" /><path d="M20 5.5C20 4.7 19.3 4 18.5 4H13v16h5.5c.8 0 1.5-.7 1.5-1.5Z" /><path d="M11 6h2" /></svg>
		{%- elif icon_key == "books" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M4.5 6.5c0-.8.7-1.5 1.5-1.5h4.5v12H6c-.8 0-1.5.7-1.5 1.5Z" /><path d="M10.5 5H15c.8 0 1.5.7 1.5 1.5V18h-4.5c-.8 0-1.5.7-1.5 1.5Z" /><path d="M16.5 7H19c.8 0 1.5.7 1.5 1.5V19h-4" /><path d="M6.5 8h2.5M12.5 8H15M17.5 10h1.5" /></svg>
		{%- elif icon_key == "compass" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8" /><path d="m15.5 8.5-2.5 7-4 2 2.5-7Z" /><path d="M12 4v2M12 18v2M4 12h2M18 12h2" /></svg>
		{%- elif icon_key == "gamepad" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M7 9h10a4 4 0 0 1 3.8 5.4l-1 3A2.5 2.5 0 0 1 17.4 19a2.5 2.5 0 0 1-1.8-.8L13.8 16h-3.6l-1.8 2.2a2.5 2.5 0 0 1-1.8.8 2.5 2.5 0 0 1-2.4-1.6l-1-3A4 4 0 0 1 7 9Z" /><path d="M8 12h3M9.5 10.5v3" /><circle cx="16.5" cy="12" r=".9" /><circle cx="18.7" cy="10.8" r=".9" /></svg>
		{%- elif icon_key == "layers" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><path d="m12 4 8 4-8 4-8-4Z" /><path d="m4 12 8 4 8-4" /><path d="m4 16 8 4 8-4" /></svg>
		{%- elif icon_key == "map" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6.5 8 4l8 2.5L21 4v13.5L16 20l-8-2.5L3 20Z" /><path d="M8 4v13.5" /><path d="M16 6.5V20" /></svg>
		{%- elif icon_key == "search" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="6" /><path d="m20 20-4.2-4.2" /></svg>
		{%- elif icon_key == "glasses" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><circle cx="7.5" cy="13" r="3.5" /><circle cx="16.5" cy="13" r="3.5" /><path d="M11 13h2M3.5 11l1-4h5l1 4M13.5 11l1-4h5l1 4" /></svg>
		{%- elif icon_key == "reader" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><circle cx="8.5" cy="6.5" r="2.2" /><path d="M6 20v-5.5a2.5 2.5 0 0 1 2.5-2.5h2" /><path d="M12.5 10 19 8.5v8l-6.5 1.5Z" /><path d="M12.5 10v8" /><path d="M15 11.5v3.5" /></svg>
		{%- elif icon_key == "notes" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><rect x="5" y="4.5" width="12" height="15" rx="1.5" /><path d="M8 8h6M8 11h6M8 14h4" /><path d="m17 16 2.5 2.5" /><path d="m18.2 14.8 1.8 1.8-2.8 2.8-1.8-1.8Z" /></svg>
		{%- elif icon_key == "message-check" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 6.5h14v9H9l-4 3z" /><path d="m10 11 2 2 4-4" /></svg>
		{%- elif icon_key == "pin" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21v-6" /><path d="M8 10V4h8v6l2 2H6Z" /></svg>
		{%- elif icon_key == "clipboard" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M9 4h6" /><rect x="6" y="5" width="12" height="15" rx="1.5" /><path d="M9 8h6" /></svg>
		{%- elif icon_key == "clipboard-notes" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M9 4h6" /><rect x="6" y="5" width="12" height="15" rx="1.5" /><path d="M9 8h6M9 11h6M9 14h4" /><path d="m15.5 15.5 2.8 2.8" /></svg>
		{%- elif icon_key == "checklist" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><path d="m5 7 1.5 1.5L9 6" /><path d="M11 7h8" /><path d="m5 12 1.5 1.5L9 11" /><path d="M11 12h8" /><path d="m5 17 1.5 1.5L9 16" /><path d="M11 17h8" /></svg>
		{%- elif icon_key == "pencil" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><path d="m4 20 4.5-1 9.7-9.7-3.5-3.5L5 15.5Z" /><path d="m13.8 6.2 3.5 3.5" /><path d="M4 20h4.5" /></svg>
		{%- elif icon_key == "stairs" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 18h4v-4h4v-4h4V6h4" /></svg>
		{%- elif icon_key == "gauge" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 16a7 7 0 1 1 14 0" /><path d="m12 12 4-3" /><path d="M12 16h.01" /></svg>
		{%- elif icon_key == "key" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><circle cx="8" cy="12" r="3" /><path d="M11 12h9" /><path d="M17 12v3" /><path d="M14 12v2" /></svg>
		{%- elif icon_key == "alert" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 4 20 19H4Z" /><path d="M12 9v4" /><path d="M12 16h.01" /></svg>
		{%- elif icon_key == "check-badge" -%}
			<svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8" /><path d="m8.5 12 2.5 2.5 4.5-5" /></svg>
		{%- endif -%}
	{%- endmacro %}

	{% macro render_section_heading(title, icon_key) -%}
		<h2 class="section-heading">
			{% set rendered_icon = icon_svg(icon_key)|trim %}
			{% if rendered_icon %}
				<span class="heading-icon" aria-hidden="true">{{ rendered_icon|safe }}</span>
			{% endif %}
			<span>{{ title }}</span>
		</h2>
	{%- endmacro %}

	{% macro render_callout(icon_key, variant='default') -%}
		<div class="callout{% if variant != 'default' %} {{ variant }}{% endif %}">
			{% set rendered_icon = icon_svg(icon_key)|trim %}
			{% if rendered_icon %}
				<span class="callout-icon" aria-hidden="true">{{ rendered_icon|safe }}</span>
			{% endif %}
			<div class="callout-text">{{ caller() }}</div>
		</div>
	{%- endmacro %}

	<section class="cover">
		<div class="eyebrow">Curriculum-Aligned Study Guide</div>
		<h1>{{ blueprint.title }}</h1>
		<p>{{ blueprint.core_concept }}</p>
		{% call render_callout(ui_icons.callout_default|default(none, true)) %}
			<strong>Essential Question:</strong> {{ blueprint.essential_question }}
		{% endcall %}
		<div class="cover-meta">
			<div class="cover-meta-item">
				<div class="eyebrow">Lesson</div>
				<div><strong>ID:</strong> {{ blueprint.lesson_id }}</div>
				<div><strong>Sub-competencies:</strong> {{ blueprint.sub_competencies|length }}</div>
			</div>
			<div class="cover-meta-item">
				<div class="eyebrow">Passage Domains</div>
				<div><strong>Model:</strong> {{ blueprint.topic_domains.model_passage }}</div>
				<div><strong>Assessment:</strong> {{ blueprint.topic_domains.assessment_passage }}</div>
			</div>
		</div>
	</section>

	{% if validation_result and validation_result.warnings %}
		<section class="section">
			{{ render_section_heading("Validation Notes", section_icons.validation_notes|default(none, true)) }}
			{% for warning in validation_result.warnings %}
				{% call render_callout(ui_icons.callout_warning|default(none, true), 'warning') %}
					{{ warning }}
				{% endcall %}
			{% endfor %}
		</section>
	{% endif %}

	{% if intro %}
		<section class="section" id="intro">
			{{ render_section_heading(intro.title, section_icons.intro|default(none, true)) }}
			{% call render_callout(ui_icons.callout_default|default(none, true)) %}{{ intro.hook }}{% endcall %}
			<p><strong>Essential Question:</strong> {{ intro.essential_question }}</p>
			{% for paragraph in intro.paragraphs %}
				<p>{{ paragraph }}</p>
			{% endfor %}
			<p><strong>Bridge to the lesson:</strong> {{ intro.bridge_to_lesson }}</p>
		</section>
	{% endif %}

	{% if learning_targets %}
		<section class="section" id="learning-targets">
			{{ render_section_heading(learning_targets.title, section_icons.learning_targets|default(none, true)) }}
			{% call render_callout(ui_icons.callout_success|default(none, true), 'success') %}
				<strong>Competency Focus:</strong>
				{{ learning_targets.competency_focus.core_concept }}
			{% endcall %}
			{% for target in learning_targets.targets %}
				<div class="target-item">
					<h3>Target {{ target.number }}</h3>
					<div class="target-meta">{{ target.bloom_verb|upper }}</div>
					<p>{{ target.objective }}</p>
					<p><strong>Success looks like:</strong> {{ target.success_look_for }}</p>
				</div>
			{% endfor %}
		</section>
	{% endif %}

	{% if warmup %}
		<section class="section" id="warmup">
			{{ render_section_heading(warmup.title, section_icons.warmup|default(none, true)) }}
			<div class="two-col">
				<div>
					<div class="boxed-list">
						<div class="eyebrow">Activity Type</div>
						<p>{{ warmup.activity_type }}</p>
						<div class="eyebrow">Purpose</div>
						<p>{{ warmup.purpose }}</p>
					</div>
				</div>
				<div>
					<div class="boxed-list">
						<div class="eyebrow">Estimated Minutes</div>
						<p>{{ warmup.estimated_minutes }}</p>
						<div class="eyebrow">Teacher Tip</div>
						<p>{{ warmup.teacher_tip }}</p>
					</div>
				</div>
			</div>
			<h3>Student Instructions</h3>
			<ol>
				{% for instruction in warmup.student_instructions %}
					<li>{{ instruction }}</li>
				{% endfor %}
			</ol>
		</section>
	{% endif %}

	{% if vocabulary %}
		<section class="section" id="vocabulary">
			{{ render_section_heading(vocabulary.title, section_icons.vocabulary|default(none, true)) }}
			<table>
				<thead>
					<tr>
						<th>Word</th>
						<th>Part of Speech</th>
						<th>Definition</th>
						<th>Example</th>
					</tr>
				</thead>
				<tbody>
					{% for entry in vocabulary.entries %}
						<tr>
							<td><strong>{{ entry.word }}</strong></td>
							<td>{{ entry.part_of_speech }}</td>
							<td>{{ entry.definition }}</td>
							<td>{{ entry.example_sentence }}</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</section>
	{% endif %}

	{% if core_explainer %}
		<section class="section" id="core-explainer">
			{{ render_section_heading(core_explainer.title, section_icons.core_explainer|default(none, true)) }}
			<p>{{ core_explainer.overview }}</p>
			{% for point in core_explainer.explained_points %}
				<div class="point-card">
					<h3>{{ point.sub_competency_label }}</h3>
					<div class="small-meta">{{ point.sub_competency_id }}</div>
					<p>{{ point.explanation }}</p>
					<p><strong>Real-world connection:</strong> {{ point.real_world_connection }}</p>
				</div>
			{% endfor %}
			{% call render_callout(ui_icons.callout_success|default(none, true), 'success') %}{{ core_explainer.closing_summary }}{% endcall %}
		</section>
	{% endif %}

	{% for subconcept in subconcepts %}
		<section class="section" id="subconcept-{{ loop.index }}">
			{{ render_section_heading(subconcept.title, section_icons.subconcept|default(none, true)) }}
			<div class="subconcept-card">
				<div class="small-meta">{{ subconcept.sub_competency_id }} | {{ subconcept.sub_competency_label }}</div>
				<p>{{ subconcept.explanation }}</p>
				<p><strong>Worked example:</strong> {{ subconcept.worked_example }}</p>
				{% call render_callout(ui_icons.callout_default|default(none, true)) %}
					<strong>Quick Check:</strong> {{ subconcept.quick_check.question }}
					<br />
					<span class="quote">Expected answer: {{ subconcept.quick_check.expected_answer }}</span>
				{% endcall %}
			</div>
		</section>
	{% endfor %}

	{% if strategy_list %}
		<section class="section" id="strategy-list">
			{{ render_section_heading(strategy_list.title, section_icons.strategy_list|default(none, true)) }}
			{% for strategy in strategy_list.strategies %}
				<div class="strategy-card">
					<h3>{{ strategy.name }}</h3>
					<p><strong>When to use:</strong> {{ strategy.when_to_use }}</p>
					<ol>
						{% for step in strategy.steps %}
							<li>{{ step }}</li>
						{% endfor %}
					</ol>
				</div>
			{% endfor %}
		</section>
	{% endif %}

	{% if deep_dive %}
		<section class="section" id="deep-dive">
			{{ render_section_heading(deep_dive.title, section_icons.deep_dive|default(none, true)) }}
			<p><strong>Compare focus:</strong> {{ deep_dive.compare_focus }}</p>
			{% for example in deep_dive.examples %}
				<div class="example-card">
					<h3>{{ example.mode|title }}</h3>
					<div class="small-meta">Topic domain: {{ example.topic_domain }}</div>
					<p>{{ example.explanation }}</p>
					<p><strong>Signal words:</strong> {{ example.signal_words|join(', ') }}</p>
				</div>
			{% endfor %}
			{% call render_callout(ui_icons.callout_success|default(none, true), 'success') %}{{ deep_dive.takeaway }}{% endcall %}
		</section>
	{% endif %}

	{% if model_passage %}
		<section class="section" id="model-passage">
			{{ render_section_heading(model_passage.title, section_icons.model_passage|default(none, true)) }}
			<p>
				<span class="badge">{{ model_passage.genre }}</span>
				<span class="badge">{{ model_passage.topic_domain }}</span>
			</p>
			<div class="passage">
				{% for paragraph in model_passage.passage %}
					<p>{{ paragraph }}</p>
				{% endfor %}
			</div>
			<p><strong>Text features:</strong> {{ model_passage.text_features|join(', ') }}</p>
			<p><strong>Evidence focus:</strong> {{ model_passage.evidence_focus }}</p>
		</section>
	{% endif %}

	{% if check_in %}
		<section class="section" id="check-in">
			{{ render_section_heading(check_in.title, section_icons.check_in|default(none, true)) }}
			{% if check_in.passage_title is defined %}
				<p><strong>Passage:</strong> {{ check_in.passage_title }}</p>
			{% endif %}
			{% for question in check_in.questions %}
				<div class="question-card">
					<h3>Question {{ question.number }}</h3>
					<p>{{ question.question }}</p>
					<p><strong>Evidence hint:</strong> {{ question.evidence_hint }}</p>
					<p><strong>Response type:</strong> {{ question.expected_response_type }}</p>
				</div>
			{% endfor %}
		</section>
	{% endif %}

	{% if key_points %}
		<section class="section" id="key-points">
			{{ render_section_heading(key_points.title, section_icons.key_points|default(none, true)) }}
			{% for point in key_points.points %}
				<div class="point-card">
					<h3>Key Point {{ point.number }}</h3>
					<div class="small-meta">{{ point.sub_competency_label }} ({{ point.sub_competency_id }})</div>
					<p>{{ point.statement }}</p>
				</div>
			{% endfor %}
		</section>
	{% endif %}

	{% if assessment_passage %}
		<section class="section page-break" id="assessment-passage">
			{{ render_section_heading(assessment_passage.title, section_icons.assessment_passage|default(none, true)) }}
			{% if assessment_passage.genre is defined %}
				<p>
					<span class="badge">{{ assessment_passage.genre }}</span>
					<span class="badge">{{ assessment_passage.topic_domain }}</span>
				</p>
			{% else %}
				<p><span class="badge">{{ assessment_passage.topic_domain }}</span></p>
			{% endif %}
			<div class="passage">
				{% for paragraph in assessment_passage.passage %}
					<p>{{ paragraph }}</p>
				{% endfor %}
			</div>
			<p><strong>Evidence clues:</strong> {{ assessment_passage.evidence_clues|join(', ') }}</p>
			{% if assessment_passage.answerability_note is defined %}
				<p><strong>Answerability note:</strong> {{ assessment_passage.answerability_note }}</p>
			{% endif %}
		</section>
	{% endif %}

	{% if assessment_questions %}
		<section class="section" id="assessment-questions">
			{{ render_section_heading(assessment_questions.title, section_icons.assessment_questions|default(none, true)) }}
			{% if assessment_questions.passage_title is defined %}
				<p><strong>Passage:</strong> {{ assessment_questions.passage_title }}</p>
			{% endif %}
			{% for question in assessment_questions.questions %}
				<div class="question-card">
					<h3>Question {{ question.number }}</h3>
					<p>{{ question.question }}</p>
					<p><strong>Type:</strong> {{ question.question_type }}</p>
					<p><strong>Answer expectation:</strong> {{ question.answer_expectation }}</p>
					<p><strong>Evidence requirement:</strong> {{ question.evidence_requirement }}</p>
				</div>
			{% endfor %}
		</section>
	{% endif %}

	{% if step_up %}
		<section class="section" id="step-up">
			{{ render_section_heading(step_up.title, section_icons.step_up|default(none, true)) }}
			{% call render_callout(ui_icons.callout_default|default(none, true)) %}
				<strong>Challenge prompt:</strong> {{ step_up.challenge_prompt }}
			{% endcall %}
			<h3>Required Evidence</h3>
			<ul>
				{% for evidence in step_up.required_evidence %}
					<li>{{ evidence }}</li>
				{% endfor %}
			</ul>
			<h3>Success Criteria</h3>
			<ul>
				{% for criterion in step_up.success_criteria %}
					<li>{{ criterion }}</li>
				{% endfor %}
			</ul>
		</section>
	{% endif %}

	{% if self_assessment %}
		<section class="section" id="self-assessment">
			{{ render_section_heading(self_assessment.title, section_icons.self_assessment|default(none, true)) }}
			<table>
				<thead>
					<tr>
						<th>Skill</th>
						{% for level in self_assessment.confidence_levels %}
							<th>{{ level }}</th>
						{% endfor %}
						<th>Reflection Prompt</th>
					</tr>
				</thead>
				<tbody>
					{% for row in self_assessment.rows %}
						<tr>
							<td>{{ row.skill }}</td>
							{% for _level in self_assessment.confidence_levels %}
								<td></td>
							{% endfor %}
							<td>{{ row.reflection_prompt }}</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</section>
	{% endif %}

	{% if answer_key %}
		<section class="section page-break" id="answer-key">
			{{ render_section_heading(answer_key.title, section_icons.answer_key|default(none, true)) }}

			{% if answer_key.check_in_answers %}
				<h3>Check-In Answers</h3>
				{% for answer in answer_key.check_in_answers %}
					<div class="answer-card">
						<h4>Question {{ answer.question_number }}</h4>
						<p>{{ answer.question }}</p>
						<p><strong>Possible answer:</strong> {{ answer.possible_answer }}</p>
						<p><strong>Evidence quote:</strong> {{ answer.evidence_quote if answer.evidence_quote is defined else "Not provided." }}</p>
					</div>
				{% endfor %}
			{% endif %}

			{% if answer_key.assessment_answers %}
				<h3>Assessment Answers</h3>
				{% for answer in answer_key.assessment_answers %}
					<div class="answer-card">
						<h4>Question {{ answer.question_number }}</h4>
						<p>{{ answer.question }}</p>
						<p><strong>Possible answer:</strong> {{ answer.possible_answer }}</p>
						<p><strong>Evidence quote:</strong> {{ answer.evidence_quote if answer.evidence_quote is defined else "Not provided." }}</p>
					</div>
				{% endfor %}
			{% endif %}

			{% if answer_key.step_up_answer is defined %}
				{% call render_callout(ui_icons.callout_success|default(none, true), 'success') %}
					<strong>Step-Up Response:</strong>
					{% if answer_key.step_up_answer.challenge_response is defined %}
						{{ answer_key.step_up_answer.challenge_response }}
					{% else %}
						{{ answer_key.step_up_answer }}
					{% endif %}
					{% if answer_key.step_up_answer.required_evidence is defined and answer_key.step_up_answer.required_evidence %}
						<br />
						<span class="quote">Required evidence: {{ answer_key.step_up_answer.required_evidence|join(', ') }}</span>
					{% endif %}
				{% endcall %}
			{% endif %}

			<p><strong>Teacher note:</strong> {{ answer_key.teacher_note }}</p>
		</section>
	{% endif %}
</body>
</html>